PRODUCT_NAME=Spectra
PRODUCT_BUNDLE_IDENTIFIER=com.umain.spectrademo

CURRENT_PROJECT_VERSION=1
MARKETING_VERSION=1.0

CODE_SIGN_ENTITLEMENTS=iosApp/iosApp.entitlements

// Signing + Meta credentials. These are empty defaults so nothing sensitive is
// tracked; the real values come from Secrets.xcconfig (gitignored). Copy
// Secrets.xcconfig.example to Secrets.xcconfig and fill it in.
TEAM_ID=
META_APP_ID=
CLIENT_TOKEN=
DEVELOPMENT_TEAM=$(TEAM_ID)

#include? "Secrets.xcconfig"
